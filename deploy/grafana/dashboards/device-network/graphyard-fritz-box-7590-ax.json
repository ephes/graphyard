          "query": "SELECT mean(\"value\") * 8 AS \"receive_bps\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'network_device' AND \"subject_id\" = 'fritz_box_7590_ax' AND \"metric\" = 'network_device.network_receive_bytes_per_second' GROUP BY time($__interval), \"traffic_scope\" fill(null)",
