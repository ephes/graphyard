      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "12.4.0",
      "repeat": "host",
      "repeatDirection": "v",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT non_negative_derivative(mean(\"value\"), 1s) * 8 AS \"receive_bps\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" =~ /^$host$/ AND \"metric\" = 'host.network_receive_bytes_total' AND \"device\" =~ /^$device$/ GROUP BY time($__interval), \"subject_id\", \"device\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT non_negative_derivative(mean(\"value\"), 1s) * 8 AS \"transmit_bps\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" =~ /^$host$/ AND \"metric\" = 'host.network_transmit_bytes_total' AND \"device\" =~ /^$device$/ GROUP BY time($__interval), \"subject_id\", \"device\" fill(null)",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        }
      ],
      "title": "Network Traffic: $host",
      "type": "timeseries"
    }
  ],
