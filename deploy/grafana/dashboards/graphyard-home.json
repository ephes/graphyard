        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT mean(\"value\") FROM \"graphyard_metrics\" WHERE $timeFilter AND (\"host\" =~ /^$host$/ OR (\"host\" = 'homeassistant' AND \"service\" = 'homeassistant')) AND \"device_class\" = 'temperature' AND \"entity_id\" =~ /^sensor\\.(fritz_box_.*|usw_pro_.*|.*cpu.*|.*fractal.*|.*macmini.*)$/ GROUP BY time($__interval), \"entity_id\" fill(null)",
