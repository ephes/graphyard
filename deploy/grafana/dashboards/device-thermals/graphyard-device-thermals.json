          "query": "SELECT mean(\"value\") FROM \"graphyard_metrics\" WHERE $timeFilter AND \"collector_host\" =~ /^$collector_host$/ AND \"source_system\" =~ /^$source_system$/ AND \"subject_type\" = 'network_device' AND \"subject_id\" =~ /^$subject_id$/ AND \"device_class\" = 'temperature' GROUP BY time($__interval), \"subject_id\" fill(null)",
