      "id": 1,
      "options": {
        "content": "Fractal-specific host thermal view. Host-side temperatures come from `lm-sensors`; board, memory, chassis, and fan tach come from local `ipmitool`. Collection stays local to Fractal and is exposed through the cached thermal endpoint.",
        "mode": "markdown"
      },
      "pluginVersion": "12.4.0",
      "title": "Scope",
      "type": "text"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "graphyard-influxdb"
      },
      "description": "Selected Fractal temperatures from the local thermal endpoint. `fractal-lm-sensors` covers CPU, GPU, and NVMe; `fractal-ipmi` covers motherboard, chipset, RAM, and chassis sensors.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "displayName": "${__field.labels.sensor_label} (${__field.labels.source_instance})",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT mean(\"value\") FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'fractal' AND \"source_system\" = 'fractal_thermal_endpoint' AND \"source_instance\" =~ /^$source_instance$/ AND \"metric\" = 'host.temperature_celsius' GROUP BY time($__interval), \"source_instance\", \"sensor_label\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Fractal Temperatures",
      "type": "timeseries"
    },
