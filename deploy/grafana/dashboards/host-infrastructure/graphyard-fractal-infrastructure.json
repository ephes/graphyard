          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 10
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [],
