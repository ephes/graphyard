    {
      "datasource": {
        "type": "influxdb",
        "uid": "graphyard-influxdb"
      },
      "description": "Read and write throughput derived from Vector disk byte counters. Loop, partition, md, and dm devices are filtered out to reduce double counting.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
