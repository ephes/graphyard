      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT sum(\"read_bps\") AS \"read_bps\" FROM (SELECT non_negative_derivative(mean(\"value\"), 1s) AS \"read_bps\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'fractal' AND \"metric\" = 'host.disk_read_bytes_total' AND \"device\" !~ /^(loop[0-9]+|ram[0-9]+|fd[0-9]+|sr[0-9]+|md[0-9]+|dm-[0-9]+|sd[a-z]+[0-9]+|vd[a-z]+[0-9]+|xvd[a-z]+[0-9]+|nvme[0-9]+n[0-9]+p[0-9]+)$/ GROUP BY time($__interval), \"device\" fill(null)) GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT sum(\"write_bps\") AS \"write_bps\" FROM (SELECT non_negative_derivative(mean(\"value\"), 1s) AS \"write_bps\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'fractal' AND \"metric\" = 'host.disk_written_bytes_total' AND \"device\" !~ /^(loop[0-9]+|ram[0-9]+|fd[0-9]+|sr[0-9]+|md[0-9]+|dm-[0-9]+|sd[a-z]+[0-9]+|vd[a-z]+[0-9]+|xvd[a-z]+[0-9]+|nvme[0-9]+n[0-9]+p[0-9]+)$/ GROUP BY time($__interval), \"device\" fill(null)) GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        }
      ],
      "title": "Disk I/O Throughput",
      "type": "timeseries"
    },
