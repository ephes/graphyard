    {
      "datasource": {
        "type": "influxdb",
        "uid": "graphyard-influxdb"
      },
      "description": "Average non-idle CPU usage derived from Vector `host.cpu_seconds_total` counters.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "displayName": "${__field.name}",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT mean(\"busy_ratio\") AS \"usage_ratio\" FROM (SELECT sum(\"mode_rate\") AS \"busy_ratio\" FROM (SELECT non_negative_derivative(mean(\"value\"), 1s) AS \"mode_rate\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'production' AND \"metric\" = 'host.cpu_seconds_total' AND \"mode\" != 'idle' GROUP BY time($__interval), \"cpu\", \"mode\" fill(null)) GROUP BY time($__interval), \"cpu\" fill(null)) GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
