  "panels": [
    {
      "datasource": null,
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
      "content": "Fractal storage view only. `rootfs`, `fast`, and `tank` all come from the Fractal storage exporter; USB state comes from the Fractal backup exporter.",
        "mode": "markdown"
      },
      "pluginVersion": "12.4.0",
      "title": "Scope",
      "type": "text"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "graphyard-influxdb"
      },
    "description": "Logical storage utilization on fractal. `rootfs` tracks the root logical volume, while `fast` and `tank` track ZFS pool usage.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.8
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          },
          "unit": "percentunit"
        },
      "overrides": [
        {
          "matcher": {
            "id": "byName",
            "options": "graphyard_metrics.rootfs"
          },
          "properties": [
            {
              "id": "displayName",
              "value": "rootfs"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "graphyard_metrics.fast"
          },
          "properties": [
            {
              "id": "displayName",
              "value": "fast"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "graphyard_metrics.tank"
          },
          "properties": [
            {
              "id": "displayName",
              "value": "tank"
            }
          ]
        }
      ]
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
        "query": "SELECT mean(\"value\") AS \"rootfs\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'fractal' AND \"metric\" = 'host.storage_filesystem_used_ratio' AND \"filesystem\" = 'rootfs' GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT mean(\"value\") AS \"fast\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'fractal' AND \"metric\" = 'host.storage_pool_used_ratio' AND \"pool\" = 'fast' GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT mean(\"value\") AS \"tank\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'fractal' AND \"metric\" = 'host.storage_pool_used_ratio' AND \"pool\" = 'tank' GROUP BY time($__interval) fill(null)",
          "rawQuery": true,
          "refId": "C",
          "resultFormat": "time_series"
        }
      ],
      "title": "Fractal Logical Storage Used",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "graphyard-influxdb"
      },
      "description": "USB backup drive state on fractal. `device_present=1` means the USB disk is attached. `pool_imported=1` means the `vault` pool is currently imported.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "text": "0"
                },
                "1": {
                  "text": "1"
                }
              },
              "type": "value"
            }
          ],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
      "overrides": [
        {
          "matcher": {
            "id": "byName",
            "options": "graphyard_metrics.device_present"
          },
          "properties": [
            {
              "id": "displayName",
              "value": "device_present"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "graphyard_metrics.pool_imported"
          },
          "properties": [
            {
              "id": "displayName",
              "value": "pool_imported"
            }
          ]
        }
      ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT last(\"value\") AS \"device_present\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'fractal' AND \"metric\" = 'host.backup_usb_device_present' AND \"backup_target\" = 'vault' GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "graphyard-influxdb"
          },
          "query": "SELECT last(\"value\") AS \"pool_imported\" FROM \"graphyard_metrics\" WHERE $timeFilter AND \"subject_type\" = 'host' AND \"subject_id\" = 'fractal' AND \"metric\" = 'host.backup_usb_pool_imported' AND \"backup_target\" = 'vault' GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        }
      ],
      "title": "Fractal USB Backup Drive State",
      "type": "timeseries"
    }
  ],
