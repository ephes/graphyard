DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-me
DJANGO_ADMIN_URL=admin/
DJANGO_LOGIN_URL=/login/
DJANGO_LOGIN_REDIRECT_URL=/
DJANGO_SESSION_COOKIE_AGE_SECONDS=86400
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=replace-me
INFLUX_ORG=graphyard
INFLUX_BUCKET=graphyard
INFLUX_MEASUREMENT=graphyard_metrics
INFLUX_TIMEOUT_MS=10000
INFLUX_API_MODE=auto

GRAFANA_BASE_URL=http://127.0.0.1:3000

GRAPHYARD_METRIC_COLLECTION_INTERVAL_SECONDS=60
GRAPHYARD_CONDITION_EVAL_INTERVAL_SECONDS=60

GRAPHYARD_HEARTBEAT_WARNING_SECONDS=900
GRAPHYARD_HEARTBEAT_CRITICAL_SECONDS=3600
GRAPHYARD_CONDITION_DATA_STALE_WARNING_SECONDS=600
