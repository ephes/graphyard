django: PYTHONUNBUFFERED=true uv run src/django/manage.py runserver 0.0.0.0:8000
agent: PYTHONUNBUFFERED=true uv run src/django/manage.py start_agent
influxdb: sh -c 'if command -v influxd >/dev/null 2>&1; then mkdir -p .dev/influxdb2; exec influxd --bolt-path .dev/influxdb2/influxd.bolt --engine-path .dev/influxdb2/engine; elif command -v influxdb3 >/dev/null 2>&1; then mkdir -p .dev/influxdb3; exec influxdb3 serve --node-id graphyard-dev --object-store file --data-dir .dev/influxdb3 --http-bind 127.0.0.1:8086 --without-auth; else echo "Neither influxd nor influxdb3 found (macOS: brew install influxdb)"; exit 1; fi'
grafana: sh -c 'if command -v docker >/dev/null 2>&1; then mkdir -p .dev/grafana; docker rm -f graphyard-grafana >/dev/null 2>&1 || true; exec docker run --rm --name graphyard-grafana -p 127.0.0.1:3000:3000 -e GF_SECURITY_ADMIN_USER=admin -e GF_SECURITY_ADMIN_PASSWORD=admin -e GF_USERS_ALLOW_SIGN_UP=false -e GF_DASHBOARDS_DEFAULT_HOME_DASHBOARD_PATH=/etc/grafana/provisioning/dashboards-json/overview/graphyard-home.json -e GRAPHYARD_INFLUX_URL=http://host.docker.internal:8086 -e GRAPHYARD_INFLUX_DB=graphyard -e GRAPHYARD_INFLUX_USER=dev -e GRAPHYARD_INFLUX_PASSWORD=dev -v "$PWD/.dev/grafana:/var/lib/grafana" -v "$PWD/deploy/grafana/provisioning:/etc/grafana/provisioning" -v "$PWD/deploy/grafana/dashboards:/etc/grafana/provisioning/dashboards-json" grafana/grafana-oss sh -c '\''grafana cli --homepath /usr/share/grafana admin reset-admin-password "$GF_SECURITY_ADMIN_PASSWORD" || true; exec /run.sh'\''; else echo "docker not found (install Docker Desktop or run Grafana separately on :3000)"; exit 1; fi'
